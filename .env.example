# ─── MindSpace — Local Environment ───────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and NEVER committed.
#
# These are server-only secrets (no VITE_ prefix) — they run in the
# TanStack Start SSR layer and are never exposed to the browser.

# Ollama Cloud base URL
OLLAMA_API_URL=https://your-ollama-instance.com

# Your Ollama Cloud API key
OLLAMA_API_KEY=your_api_key_here

# Model to use
OLLAMA_MODEL=your_model_name_here
